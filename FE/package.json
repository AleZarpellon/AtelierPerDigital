{
  "main": "electron/main.js",
  "name": "fe",
  "version": "1.0.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "electron:dev": "concurrently \"ng serve\" \"wait-on http://localhost:4200 && electron .\"",
    "electron:build": "rimraf release && ng build --configuration production && electron-builder",
    "electron:release": "rimraf release && ng build --configuration production && electron-builder --publish always",
    "build:all": "cd ../BE && mvn clean package -DskipTests && cd ../FE && npm install && npx tsc -p tsconfig.electron.json && npm run electron:build",
    "release:patch": "npm version patch --no-git-tag-version && node release.js",
    "release:minor": "npm version minor --no-git-tag-version && node release.js",
    "release:major": "npm version major --no-git-tag-version && node release.js"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "21.2.6",
    "@angular/common": "21.2.6",
    "@angular/compiler": "21.2.6",
    "@angular/core": "21.2.6",
    "@angular/forms": "21.2.6",
    "@angular/platform-browser": "21.2.6",
    "@angular/router": "21.2.6",
    "@primeng/themes": "^21.0.4",
    "@tailwindcss/postcss": "^4.2.2",
    "electron-updater": "^6.8.3",
    "postcss": "^8.5.8",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.5",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.6",
    "@angular/cli": "21.2.6",
    "@angular/compiler-cli": "21.2.6",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.1",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.atelierperdigital.id",
    "productName": "AtelierPerDigital",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "asar": true,
    "asarUnpack": [
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/uninstaller.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AleZarpellon",
        "repo": "AtelierPerDigital",
        "releaseType": "release"
      }
    ]
  }
}
